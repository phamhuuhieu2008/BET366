        <div class="flex flex-col items-center w-full shrink-0 gap-2">
            <!-- Lịch sử phiên (Chấm tròn) -->
            <div id="xocDiaHistory" class="flex gap-1.5 justify-center overflow-x-auto no-scrollbar max-w-lg mx-auto py-1 px-4 bg-black/30 rounded-full border border-white/5">
                <!-- History dots -->
            </div>
            
            <!-- Chuỗi Hash MD5 -->
            <div class="flex items-center justify-between w-full max-w-lg mx-auto bg-black/60 border border-yellow-500/40 rounded-full pl-4 pr-1 py-1 shadow-inner">
                <span class="text-[10px] sm:text-xs text-yellow-500 font-black uppercase whitespace-nowrap mr-2">CHUỖI HASH</span>
                <span class="text-[9px] sm:text-xs text-zinc-300 font-mono truncate flex-1 text-center select-all" id="xdMd5HashDisplay">c81e728d9d4c2f636f067f89cc14862c</span>
                <button onclick="copyXDHash()" class="bg-gradient-to-r from-yellow-500 to-yellow-600 text-black font-black text-[10px] sm:text-xs px-3 py-1.5 rounded-full shadow hover:scale-105 active:scale-95 transition haptic-btn ml-2">
                    COPY
                </button>
            </div>
        </div>

        <!-- BẢNG ĐẶT CƯỢC NHANH XÓC ĐĨA (Hiển thị khi bấm CƯỢC) -->
        <div id="quickXocDiaBetPanel" class="absolute inset-x-8 bottom-6 bg-zinc-900/95 backdrop-blur-xl border-2 border-yellow-500/50 rounded-3xl p-4 shadow-2xl hidden flex-col z-50 animate-slideUp">
            <div class="flex justify-between items-center mb-3 border-b border-white/10 pb-2">
                <span class="text-xs font-black text-yellow-500 uppercase tracking-wider" id="quickXocDiaBetTitle">ĐẶT CƯỢC XÓC ĐĨA</span>
                <i class="fa-solid fa-xmark text-white text-lg cursor-pointer hover:text-red-500 transition" onclick="closeQuickXocDiaBet()"></i>
            </div>
            <div class="flex justify-center gap-2 overflow-x-auto no-scrollbar py-2 mb-3">
                <div onclick="addXocDiaBetAmount(10000)" class="chip chip-10k scale-90 sm:scale-100 cursor-pointer">10K</div>
                <div onclick="addXocDiaBetAmount(50000)" class="chip chip-50k scale-90 sm:scale-100 cursor-pointer">50K</div>
                <div onclick="addXocDiaBetAmount(100000)" class="chip chip-100k scale-90 sm:scale-100 cursor-pointer">100K</div>
                <div onclick="addXocDiaBetAmount(500000)" class="chip chip-500k scale-90 sm:scale-100 cursor-pointer">500K</div>
                <div onclick="setXocDiaAllIn()" class="chip chip-max scale-90 sm:scale-100 cursor-pointer">MAX</div>
            </div>
            <div class="hitclub-input-group flex gap-2">
                <input type="number" id="xocDiaBetAmount" value="10000" class="flex-1 bg-black/60 border border-yellow-500/30 rounded-xl px-4 py-2 text-white font-black text-lg outline-none focus:border-yellow-500" />
                <button onclick="playXocDia()" id="xocDiaSpinBtn" class="bg-gradient-to-r from-yellow-400 to-yellow-600 text-black px-8 py-2.5 rounded-xl font-black text-sm haptic-btn shadow-lg hover:scale-105 active:scale-95 transition">XÁC NHẬN</button>
            </div>
        </div>

    </div>
</div>

<!-- Bầu Cua Game Overlay -->
<div id="bauCuaGame" class="fixed inset-0 z-[200] bg-black/95 hidden flex-col overflow-hidden">
    <header class="px-4 py-1 flex items-center justify-between border-b border-white/5 shrink-0">
        <div onclick="toggleGame('bauCua')" class="h-10 w-10 flex items-center justify-center bg-zinc-900 rounded-full text-white haptic-btn">
            <i class="fa-solid fa-chevron-left"></i>
        </div>
        <div class="flex flex-col items-center">
            <span class="text-[8px] text-zinc-500 font-black uppercase tracking-[0.3em]">Game phiên</span>
            <span class="text-[10px] font-bold text-yellow-500">#BC9999</span>
            <div class="text-[9px] font-black text-yellow-400 mt-0.5"><i class="fa-solid fa-wallet mr-1"></i><span class="mini-balance">0</span></div>
        </div>
        <div class="h-10 w-10 flex items-center justify-center bg-zinc-900 rounded-full text-yellow-500">
            <i class="fa-solid fa-circle-info"></i>
        </div>
    </header>

    <div class="flex-1 flex flex-col items-center justify-center p-4 space-y-4 overflow-hidden">
        <!-- Status & Timer -->
        <div class="text-center shrink-0">
            <div id="bauCuaPhaseText" class="text-[9px] text-zinc-500 uppercase font-black tracking-widest mb-1">Đang đặt cược</div>
            <div id="bauCuaCountdown" class="text-4xl font-black text-yellow-400 font-mono">35</div>
            <!-- Lịch sử Bầu Cua -->
            <div id="bauCuaHistory" class="flex gap-1 justify-center mt-2 opacity-80 scale-75"></div>
        </div>

        <!-- Result Dices -->
        <div id="bauCuaResults" class="flex gap-2 sm:gap-4 justify-center py-2 shrink-0">
            <div class="w-10 h-10 sm:w-16 sm:h-16 bg-zinc-800 rounded-xl flex items-center justify-center text-xl sm:text-3xl shadow-xl border border-white/5">🦌</div>
            <div class="w-10 h-10 sm:w-16 sm:h-16 bg-zinc-800 rounded-xl flex items-center justify-center text-xl sm:text-3xl shadow-xl border border-white/5">🦀</div>
            <div class="w-10 h-10 sm:w-16 sm:h-16 bg-zinc-800 rounded-xl flex items-center justify-center text-xl sm:text-3xl shadow-xl border border-white/5">🎃</div>
        </div>

        <!-- Betting Board -->
        <div class="grid grid-cols-3 gap-1 w-full max-w-sm shrink-0">
            <div id="bc-nai" onclick="selectBauCuaChoice('nai')" class="relative aspect-square bg-zinc-900/50 rounded-2xl border border-white/5 flex flex-col items-center justify-center gap-1 haptic-btn transition-all">
                <span id="placedBetBC-nai" class="bet-badge hidden pointer-events-none">0đ</span>
                <span class="text-3xl sm:text-4xl">🦌</span>
                <span class="text-[8px] sm:text-[10px] font-black text-zinc-500">NAI</span>
            </div>
            <div id="bc-bau" onclick="selectBauCuaChoice('bau')" class="relative aspect-square bg-zinc-900/50 rounded-2xl border border-white/5 flex flex-col items-center justify-center gap-1 haptic-btn transition-all">
                <span id="placedBetBC-bau" class="bet-badge hidden pointer-events-none">0đ</span>
                <span class="text-3xl sm:text-4xl">🎃</span>
                <span class="text-[8px] sm:text-[10px] font-black text-zinc-500">BẦU</span>
            </div>
            <div id="bc-ga" onclick="selectBauCuaChoice('ga')" class="relative aspect-square bg-zinc-900/50 rounded-2xl border border-white/5 flex flex-col items-center justify-center gap-1 haptic-btn transition-all">
                <span id="placedBetBC-ga" class="bet-badge hidden pointer-events-none">0đ</span>
                <span class="text-3xl sm:text-4xl">🐓</span>
                <span class="text-[8px] sm:text-[10px] font-black text-zinc-500">GÀ</span>
            </div>
            <div id="bc-ca" onclick="selectBauCuaChoice('ca')" class="relative aspect-square bg-zinc-900/50 rounded-2xl border border-white/5 flex flex-col items-center justify-center gap-1 haptic-btn transition-all">
                <span id="placedBetBC-ca" class="bet-badge hidden pointer-events-none">0đ</span>
                <span class="text-3xl sm:text-4xl">🐟</span>
                <span class="text-[8px] sm:text-[10px] font-black text-zinc-500">CÁ</span>
            </div>
            <div id="bc-cua" onclick="selectBauCuaChoice('cua')" class="relative aspect-square bg-zinc-900/50 rounded-2xl border border-white/5 flex flex-col items-center justify-center gap-1 haptic-btn transition-all">
                <span id="placedBetBC-cua" class="bet-badge hidden pointer-events-none">0đ</span>
                <span class="text-3xl sm:text-4xl">🦀</span>
                <span class="text-[8px] sm:text-[10px] font-black text-zinc-500">CUA</span>
            </div>
            <div id="bc-tom" onclick="selectBauCuaChoice('tom')" class="relative aspect-square bg-zinc-900/50 rounded-2xl border border-white/5 flex flex-col items-center justify-center gap-1 haptic-btn transition-all">
                <span id="placedBetBC-tom" class="bet-badge hidden pointer-events-none">0đ</span>
                <span class="text-3xl sm:text-4xl">🦐</span>
                <span class="text-[8px] sm:text-[10px] font-black text-zinc-500">TÔM</span>
            </div>
        </div>

        <!-- Bet Input -->
        <div class="w-full max-w-sm px-2 pb-4 shrink-0">
            <div class="hitclub-input-group">
                <input type="number" id="bauCuaBetAmount" value="10000" />
                <button onclick="playBauCua()" id="playBauCuaBtn" class="bg-gradient-to-b from-emerald-500 to-emerald-800 text-white px-6 py-3 rounded-xl font-black text-sm haptic-btn shadow-lg">ĐẶT CƯỢC</button>
            </div>
        </div>
    </div>
</div>

