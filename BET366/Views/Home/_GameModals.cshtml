<!-- Modal Trang Cá Nhân (Hitclub Style) -->
<div id="profileModal" class="fixed inset-0 bg-black/80 z-[200] hidden flex items-center justify-center p-4 backdrop-blur-sm">
    <div class="relative w-full max-w-md bg-gradient-to-br from-[#2a0404] to-[#0a0000] border-2 border-[#d4af37] rounded-xl shadow-[0_0_30px_rgba(212,175,55,0.3)] overflow-hidden">
        
        <!-- Header -->
        <div class="h-12 bg-gradient-to-r from-[#d4af37] to-[#8b6508] border-b border-[#fff]/20 flex justify-center items-center relative">
            <h2 class="text-black font-black text-lg sm:text-xl uppercase tracking-widest drop-shadow-md">TRANG CÁ NHÂN</h2>
            <button onclick="closeModal('profileModal')" class="absolute right-2 w-8 h-8 flex items-center justify-center bg-black/20 hover:bg-black/40 rounded-full text-black transition">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>

        <div class="p-6 space-y-6">
            <div class="flex flex-col items-center gap-3">
                <div class="relative w-24 h-24 rounded-full border-4 border-[#d4af37] p-1 shadow-[0_0_15px_rgba(212,175,55,0.5)]">
                    <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=@User.Identity?.Name" alt="Avatar" class="w-full h-full rounded-full bg-[#1a0a0a]" />
                    <div class="absolute -bottom-2 right-0 bg-gradient-to-r from-[#d4af37] to-[#ffd700] text-black text-xs font-black px-2 py-0.5 rounded border border-black shadow-lg uppercase">VIP 1</div>
                </div>
                <div class="text-center">
                    <p id="profileUsernameModal" class="text-2xl font-black text-[#ffd700] drop-shadow-md">@User.Identity?.Name</p>
                    <p class="text-xs text-gray-400 mt-1">ID: 104829</p>
                </div>
            </div>

            <div class="space-y-4 mt-4">
                <div class="bg-black/40 p-4 rounded-xl border border-[#d4af37]/30 text-center flex items-center justify-center gap-3">
                    <i class="fa-solid fa-wallet text-2xl text-[#ffd700]"></i>
                    <div>
                        <p class="text-[10px] text-gray-400 uppercase font-black mb-1">Số dư hiện tại</p>
