                </div>
                <div class="space-y-1">
                    <label class="text-[#ffd700] text-xs font-bold uppercase ml-1">Số điện thoại</label>
                    <input type="text" id="profilePhone" class="w-full bg-[#1a0a0a] border border-[#d4af37]/50 rounded-lg p-3 text-white outline-none" placeholder="VD: 0912345678" />
                </div>
            </div>

            <button type="button" onclick="saveProfile()" class="w-full bg-gradient-to-b from-[#ffd700] to-[#b8860b] text-black font-black text-lg py-3 rounded-lg shadow-[0_0_15px_rgba(212,175,55,0.4)] hover:scale-[1.02] transition uppercase mt-4">Lưu Cập Nhật</button>
        </div>
    </div>
</div>

<!-- Modal Biểu Đồ Chi Tiết -->
<div id="chartModal" class="fixed inset-0 bg-black/95 z-[300] hidden flex items-center justify-center p-4">
    <div class="modal-glass w-full max-w-4xl rounded-[40px] overflow-hidden flex flex-col max-h-[90vh]">
        <div class="relative p-6 text-center border-b border-white/5 bg-zinc-900/50">
            <h3 class="text-xl font-black gold-gradient-text uppercase tracking-widest">Lịch Sử Phiên Chi Tiết</h3>
            <button onclick="closeModal('chartModal')" class="absolute right-6 top-6 text-zinc-500 hover:text-white transition">
                <i class="fa-solid fa-circle-xmark text-2xl"></i>
            </button>
        </div>

        <div class="p-4 flex-1 overflow-y-auto custom-scroll space-y-4">
