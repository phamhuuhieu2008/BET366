<!-- 
    BET366 LUXURY MODALS
    Glassmorphism + Neon accents
-->

<style>
    .modal-glass {
        background: rgba(10, 10, 10, 0.95);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 223, 0, 0.1);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }
    .input-luxury {
        background: rgba(0, 0, 0, 0.5) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        transition: all 0.3s;
    }
    .input-luxury:focus {
        border-color: #ffdf00 !important;
        box-shadow: 0 0 15px rgba(255, 223, 0, 0.2);
    }
    .btn-gold-luxury {
        background: linear-gradient(180deg, #ffdf00 0%, #b8860b 100%);
        color: black;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: all 0.3s;
    }
    .btn-gold-luxury:hover {
        transform: scale(1.02);
        box-shadow: 0 0 20px rgba(255, 223, 0, 0.4);
    }
    .history-card {
        background: linear-gradient(90deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%);
        border-left: 3px solid #ffdf00;
    }
</style>

<!-- Modal Nạp Tiền (Hitclub Style) -->
<div id="depositModal" class="fixed inset-0 bg-black/80 z-[200] hidden flex items-center justify-center p-2 sm:p-4 backdrop-blur-sm">
    <div class="relative w-full max-w-4xl bg-gradient-to-br from-[#2a0404] to-[#0a0000] border-2 border-[#d4af37] rounded-xl shadow-[0_0_30px_rgba(212,175,55,0.3)] flex flex-col h-[85vh] sm:h-[600px] overflow-hidden">
        
        <!-- Header -->
        <div class="h-12 bg-gradient-to-r from-[#d4af37] to-[#8b6508] border-b border-[#fff]/20 flex justify-center items-center relative">
            <h2 class="text-black font-black text-lg sm:text-xl uppercase tracking-widest drop-shadow-md">NẠP TIỀN</h2>
            <button onclick="closeModal('depositModal')" class="absolute right-2 w-8 h-8 flex items-center justify-center bg-black/20 hover:bg-black/40 rounded-full text-black transition">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>

        <div class="flex flex-1 overflow-hidden">
            <!-- Sidebar (Methods) -->
            <div class="w-24 sm:w-48 bg-black/60 border-r border-[#d4af37]/30 flex flex-col overflow-y-auto custom-scroll">
                <button class="w-full p-3 flex flex-col sm:flex-row items-center sm:gap-3 border-l-4 border-[#d4af37] bg-[#d4af37]/10 text-[#ffd700] hover:bg-[#d4af37]/20 transition">
                    <i class="fa-solid fa-building-columns text-xl sm:text-2xl"></i>
                    <span class="text-[10px] sm:text-xs font-black uppercase mt-1 sm:mt-0">Ngân hàng</span>
                </button>
                <button class="w-full p-3 flex flex-col sm:flex-row items-center sm:gap-3 border-l-4 border-transparent text-gray-400 hover:bg-[#d4af37]/10 transition">
                    <i class="fa-solid fa-qrcode text-xl sm:text-2xl"></i>
                    <span class="text-[10px] sm:text-xs font-black uppercase mt-1 sm:mt-0">CodePay</span>
                </button>
                <button class="w-full p-3 flex flex-col sm:flex-row items-center sm:gap-3 border-l-4 border-transparent text-gray-400 hover:bg-[#d4af37]/10 transition">
                    <i class="fa-solid fa-wallet text-xl sm:text-2xl"></i>
                    <span class="text-[10px] sm:text-xs font-black uppercase mt-1 sm:mt-0">Ví Điện Tử</span>
                </button>
                <button class="w-full p-3 flex flex-col sm:flex-row items-center sm:gap-3 border-l-4 border-transparent text-gray-400 hover:bg-[#d4af37]/10 transition">
                    <i class="fa-solid fa-money-check text-xl sm:text-2xl"></i>
                    <span class="text-[10px] sm:text-xs font-black uppercase mt-1 sm:mt-0">Thẻ Cào</span>
                </button>
            </div>

            <!-- Content Area -->
            <div class="flex-1 p-4 sm:p-6 overflow-y-auto custom-scroll relative">
                <!-- Watermark -->
                <i class="fa-solid fa-building-columns absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[150px] text-white/5 pointer-events-none"></i>
                
                <div id="depositStep1" class="relative z-10 max-w-md mx-auto space-y-4">
                    <div class="bg-black/40 p-4 rounded-xl border border-[#d4af37]/30">
                        <label class="text-[#ffd700] text-xs font-black uppercase mb-2 block">Chọn Ngân Hàng</label>
                        <select class="w-full bg-[#1a0a0a] border border-[#d4af37]/50 rounded-lg p-3 text-white outline-none">
                            <option>Vietcombank</option>
                            <option>Techcombank</option>
                            <option>MB Bank</option>
                            <option>ACB</option>
                        </select>
                    </div>

                    <div class="bg-black/40 p-4 rounded-xl border border-[#d4af37]/30">
                        <label class="text-[#ffd700] text-xs font-black uppercase mb-2 block">Số Tiền Nạp (VNĐ)</label>
                        <input type="number" id="depositAmount" class="w-full bg-[#1a0a0a] border border-[#d4af37]/50 rounded-lg p-3 text-white font-black text-xl outline-none" placeholder="100,000" />
                        
                        <div class="grid grid-cols-4 gap-2 mt-3">
                            <button onclick="document.getElementById('depositAmount').value=50000" class="bg-[#2a1010] text-[#ffd700] border border-[#d4af37]/30 rounded text-[10px] font-bold py-1.5 hover:bg-[#d4af37] hover:text-black transition">50K</button>
                            <button onclick="document.getElementById('depositAmount').value=100000" class="bg-[#2a1010] text-[#ffd700] border border-[#d4af37]/30 rounded text-[10px] font-bold py-1.5 hover:bg-[#d4af37] hover:text-black transition">100K</button>
                            <button onclick="document.getElementById('depositAmount').value=500000" class="bg-[#2a1010] text-[#ffd700] border border-[#d4af37]/30 rounded text-[10px] font-bold py-1.5 hover:bg-[#d4af37] hover:text-black transition">500K</button>
                            <button onclick="document.getElementById('depositAmount').value=1000000" class="bg-[#2a1010] text-[#ffd700] border border-[#d4af37]/30 rounded text-[10px] font-bold py-1.5 hover:bg-[#d4af37] hover:text-black transition">1M</button>
                        </div>
                    </div>

                    <button type="button" onclick="showTransferInfo()" class="w-full bg-gradient-to-b from-[#ffd700] to-[#b8860b] text-black font-black text-lg py-3 rounded-lg shadow-[0_0_15px_rgba(212,175,55,0.4)] hover:scale-[1.02] transition uppercase">Tiếp Tục</button>
                </div>

                <!-- Step 2: Transfer Info (Hidden by default) -->
                <div id="depositStep2" class="relative z-10 max-w-md mx-auto space-y-4 hidden">
                    <div class="bg-white p-2 rounded-xl w-40 h-40 mx-auto shadow-[0_0_20px_rgba(255,255,255,0.2)]">
                        <img id="qrCodeImg" src="" alt="QR" class="w-full h-full object-contain" />
                    </div>
                    
                    <div class="bg-[#1a0a0a] border border-[#d4af37]/50 rounded-xl p-4 space-y-2">
                        <div class="flex justify-between border-b border-white/10 pb-2"><span class="text-gray-400 text-xs">Ngân hàng:</span><span id="dispBankName" class="text-white font-bold"></span></div>
                        <div class="flex justify-between border-b border-white/10 pb-2"><span class="text-gray-400 text-xs">Số TK:</span><span id="dispBankAccount" class="text-[#ffd700] font-black tracking-wider"></span></div>
                        <div class="flex justify-between border-b border-white/10 pb-2"><span class="text-gray-400 text-xs">Tên người nhận:</span><span id="dispBankHolder" class="text-white font-bold"></span></div>
                        <div class="flex justify-between border-b border-white/10 pb-2"><span class="text-gray-400 text-xs">Số tiền:</span><span id="displayDepositAmount" class="text-red-500 font-black"></span></div>
                        <div class="flex justify-between pt-1"><span class="text-gray-400 text-xs">Nội dung chuyển:</span><span id="dispTransferMsg" class="bg-[#d4af37]/20 text-[#ffd700] px-2 py-0.5 rounded font-black"></span></div>
                    </div>

                    <div class="space-y-1">
                        <label class="text-[#ffd700] text-[10px] font-bold uppercase">Nhập Tên Người Chuyển (Xác nhận)</label>
                        <input type="text" id="confirmSenderName" class="w-full bg-[#1a0a0a] border border-[#d4af37]/50 rounded-lg p-3 text-white outline-none" placeholder="VD: NGUYEN VAN A" />
                    </div>

                    <div class="flex gap-2">
                        <button onclick="closeModal('depositModal')" class="flex-1 bg-gray-600 text-white font-bold py-3 rounded-lg hover:bg-gray-500 transition">Hủy</button>
                        <button onclick="confirmDeposit()" class="flex-[2] bg-gradient-to-b from-[#ffd700] to-[#b8860b] text-black font-black py-3 rounded-lg shadow-[0_0_15px_rgba(212,175,55,0.4)] transition uppercase">Đã Chuyển Tiền</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Rút Tiền (Hitclub Style) -->
<div id="withdrawModal" class="fixed inset-0 bg-black/80 z-[200] hidden flex items-center justify-center p-2 sm:p-4 backdrop-blur-sm">
    <div class="relative w-full max-w-4xl bg-gradient-to-br from-[#2a0404] to-[#0a0000] border-2 border-[#d4af37] rounded-xl shadow-[0_0_30px_rgba(212,175,55,0.3)] flex flex-col h-[85vh] sm:h-[600px] overflow-hidden">
        
        <!-- Header -->
        <div class="h-12 bg-gradient-to-r from-[#d4af37] to-[#8b6508] border-b border-[#fff]/20 flex justify-center items-center relative">
            <h2 class="text-black font-black text-lg sm:text-xl uppercase tracking-widest drop-shadow-md">RÚT TIỀN</h2>
            <button onclick="closeModal('withdrawModal')" class="absolute right-2 w-8 h-8 flex items-center justify-center bg-black/20 hover:bg-black/40 rounded-full text-black transition">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>

        <div class="flex flex-1 overflow-hidden">
            <!-- Sidebar -->
            <div class="w-24 sm:w-48 bg-black/60 border-r border-[#d4af37]/30 flex flex-col overflow-y-auto custom-scroll">
                <button class="w-full p-3 flex flex-col sm:flex-row items-center sm:gap-3 border-l-4 border-[#d4af37] bg-[#d4af37]/10 text-[#ffd700] hover:bg-[#d4af37]/20 transition">
                    <i class="fa-solid fa-building-columns text-xl sm:text-2xl"></i>
                    <span class="text-[10px] sm:text-xs font-black uppercase mt-1 sm:mt-0">Ngân hàng</span>
                </button>
                <button class="w-full p-3 flex flex-col sm:flex-row items-center sm:gap-3 border-l-4 border-transparent text-gray-400 hover:bg-[#d4af37]/10 transition">
                    <i class="fa-solid fa-money-check text-xl sm:text-2xl"></i>
                    <span class="text-[10px] sm:text-xs font-black uppercase mt-1 sm:mt-0">Thẻ Cào</span>
                </button>
            </div>

            <!-- Content Area -->
            <div class="flex-1 p-4 sm:p-6 overflow-y-auto custom-scroll relative">
                <!-- Watermark -->
                <i class="fa-solid fa-hand-holding-dollar absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[150px] text-white/5 pointer-events-none"></i>
                
                <div class="relative z-10 max-w-md mx-auto space-y-4">
                    
                    <div class="bg-black/40 p-4 rounded-xl border border-[#d4af37]/30 space-y-3">
                        <div>
                            <label class="text-[#ffd700] text-xs font-black uppercase mb-1 block">Ngân hàng thụ hưởng</label>
                            <select id="withdrawBank" class="w-full bg-[#1a0a0a] border border-[#d4af37]/50 rounded-lg p-3 text-white outline-none">
                                <option>Vietcombank</option><option>MB Bank</option><option>Techcombank</option><option>Vietinbank</option>
                            </select>
                        </div>
                        <div>
                            <label class="text-[#ffd700] text-xs font-black uppercase mb-1 block">Tên tài khoản</label>
                            <input type="text" id="withdrawHolder" class="w-full bg-[#1a0a0a] border border-[#d4af37]/50 rounded-lg p-3 text-white outline-none uppercase" placeholder="NGUYEN VAN A" />
                        </div>
                        <div>
                            <label class="text-[#ffd700] text-xs font-black uppercase mb-1 block">Số tài khoản</label>
                            <input type="text" id="withdrawNumber" class="w-full bg-[#1a0a0a] border border-[#d4af37]/50 rounded-lg p-3 text-white outline-none" placeholder="Nhập số tài khoản" />
                        </div>
                    </div>

                    <div class="bg-black/40 p-4 rounded-xl border border-[#d4af37]/30">
                        <label class="text-[#ffd700] text-xs font-black uppercase mb-2 block">Số Tiền Rút (VNĐ)</label>
                        <input type="number" id="withdrawAmount" class="w-full bg-[#1a0a0a] border border-[#d4af37]/50 rounded-lg p-3 text-white font-black text-xl outline-none" placeholder="Tối thiểu 100,000" />
                        <div class="flex justify-between items-center mt-2">
                            <span class="text-gray-400 text-xs">Phí rút tiền: 0đ</span>
                            <span class="text-[#d4af37] text-xs cursor-pointer hover:underline">Rút toàn bộ</span>
                        </div>
                    </div>

                    <button type="button" onclick="handleWithdraw()" class="w-full bg-gradient-to-b from-[#ffd700] to-[#b8860b] text-black font-black text-lg py-3 rounded-lg shadow-[0_0_15px_rgba(212,175,55,0.4)] hover:scale-[1.02] transition uppercase">Rút Tiền</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Lịch Sử (Hitclub Style) -->
<div id="historyModal" class="fixed inset-0 bg-black/80 z-[200] hidden flex items-center justify-center p-2 sm:p-4 backdrop-blur-sm">
    <div class="relative w-full max-w-4xl bg-gradient-to-br from-[#2a0404] to-[#0a0000] border-2 border-[#d4af37] rounded-xl shadow-[0_0_30px_rgba(212,175,55,0.3)] flex flex-col h-[85vh] sm:h-[600px] overflow-hidden">
        
        <!-- Header -->
        <div class="h-12 bg-gradient-to-r from-[#d4af37] to-[#8b6508] border-b border-[#fff]/20 flex justify-center items-center relative">
            <h2 class="text-black font-black text-lg sm:text-xl uppercase tracking-widest drop-shadow-md">LỊCH SỬ GIAO DỊCH</h2>
            <button onclick="closeModal('historyModal')" class="absolute right-2 w-8 h-8 flex items-center justify-center bg-black/20 hover:bg-black/40 rounded-full text-black transition">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>

        <div class="flex flex-1 overflow-hidden">
            <!-- Sidebar -->
            <div class="w-24 sm:w-48 bg-black/60 border-r border-[#d4af37]/30 flex flex-col overflow-y-auto custom-scroll">
                <button onclick="switchHistoryTab('bet')" id="tabBet" class="w-full p-3 flex flex-col sm:flex-row items-center sm:gap-3 border-l-4 border-[#d4af37] bg-[#d4af37]/10 text-[#ffd700] hover:bg-[#d4af37]/20 transition">
                    <i class="fa-solid fa-dice text-xl sm:text-2xl"></i>
                    <span class="text-[10px] sm:text-xs font-black uppercase mt-1 sm:mt-0 text-left">Lịch Sử Cược</span>
                </button>
                <button onclick="switchHistoryTab('deposit')" id="tabDeposit" class="w-full p-3 flex flex-col sm:flex-row items-center sm:gap-3 border-l-4 border-transparent text-gray-400 hover:bg-[#d4af37]/10 transition">
                    <i class="fa-solid fa-piggy-bank text-xl sm:text-2xl"></i>
                    <span class="text-[10px] sm:text-xs font-black uppercase mt-1 sm:mt-0 text-left">Lịch Sử Nạp</span>
                </button>
                <button onclick="switchHistoryTab('withdraw')" id="tabWithdraw" class="w-full p-3 flex flex-col sm:flex-row items-center sm:gap-3 border-l-4 border-transparent text-gray-400 hover:bg-[#d4af37]/10 transition">
                    <i class="fa-solid fa-money-bill-transfer text-xl sm:text-2xl"></i>
                    <span class="text-[10px] sm:text-xs font-black uppercase mt-1 sm:mt-0 text-left">Lịch Sử Rút</span>
                </button>
            </div>

            <!-- Content Area -->
            <div class="flex-1 p-4 sm:p-6 overflow-y-auto custom-scroll relative">
                <!-- Watermark -->
                <i class="fa-solid fa-clock-rotate-left absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[150px] text-white/5 pointer-events-none"></i>
                
                <div class="relative z-10 space-y-3">
                    <div id="betHistoryList" class="space-y-3"></div>
                    <div id="depositHistoryList" class="space-y-3 hidden"></div>
                    <div id="withdrawHistoryList" class="space-y-3 hidden"></div>
                </div>
            </div>
        </div>
    </div>
</div>

