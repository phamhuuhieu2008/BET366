@model List<BET366.Models.SystemConfig>
@{ 
    Layout = "_AdminLayout"; 
    ViewData["Title"] = "Quản lý cài đặt trò chơi"; 
}

<h1 class="text-2xl font-black mb-8">🎮 Quản lý cài đặt trò chơi</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="bg-emerald-500/20 text-emerald-400 px-4 py-3 rounded-xl mb-6">
        @TempData["SuccessMessage"]
    </div>
}

<div class="admin-card p-6">
    <form asp-controller="AdminGame" asp-action="Update" method="post">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            @foreach (var config in Model)
            {
                <div class="space-y-1">
                    <label for="@config.ConfigKey" class="block text-sm font-bold text-gray-400">
                        @config.Description (@config.ConfigKey)
                    </label>
                    @if (config.ConfigKey == "FakeBetEnabled")
                    {
                        <select name="@config.ConfigKey" id="@config.ConfigKey" class="w-full input-admin">
                            <option value="true" selected="@(config.ConfigValue == "true")">Bật</option>
                            <option value="false" selected="@(config.ConfigValue == "false")">Tắt</option>
                        </select>
                    }
                    else
                    {
                        <input type="text" 
                               name="@config.ConfigKey" 
                               id="@config.ConfigKey" 
                               value="@config.ConfigValue" 
                               class="w-full input-admin" 
                               placeholder="@config.Description" />
                    }
                </div>
            }
        </div>

        <button type="submit" class="btn-primary mt-8">Lưu cài đặt</button>
    </form>
</div>

@section Scripts {
<script>
    // Thêm CSS cho input admin nếu chưa có
    const style = document.createElement('style');
    style.innerHTML = `
        .input-admin {
            background-color: #1a1a1a;
            border: 1px solid #333;
            color: #fff;
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            outline: none;
            transition: border-color 0.2s;
        }
        .input-admin:focus {
            border-color: #facc15; /* yellow-400 */
        }
    `;
    document.head.appendChild(style);
</script>
}