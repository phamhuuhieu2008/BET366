@model BET366.Models.ViewModels.LoginViewModel
@{ Layout = "_Layout"; ViewData["Title"] = "Đăng nhập - BET366"; }

<div class="fixed inset-0 z-[1000] bg-black/80 flex items-center justify-center p-4 backdrop-blur-sm">
    <div class="w-full max-w-[450px] bg-gradient-to-br from-[#2a0404] to-[#0a0000] rounded-xl p-8 border-2 border-[#d4af37] shadow-[0_0_30px_rgba(212,175,55,0.3)] relative overflow-hidden">
        
        <!-- Watermark -->
        <i class="fa-solid fa-crown absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[150px] text-white/5 pointer-events-none"></i>

        <div class="text-center mb-6 relative z-10">
            <h2 class="text-3xl font-black bg-gradient-to-r from-[#d4af37] to-[#ffd700] text-transparent bg-clip-text uppercase tracking-widest drop-shadow-md mb-1">ĐĂNG NHẬP</h2>
            <p class="text-[#d4af37]/70 text-[10px] uppercase font-bold tracking-[0.2em]">Cổng Game Bài Đổi Thưởng Đẳng Cấp</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="bg-red-900/30 border border-red-500/50 text-red-400 px-4 py-2 rounded-lg mb-4 text-xs font-bold text-center uppercase tracking-wider relative z-10">@ViewBag.Error</div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="bg-green-900/30 border border-green-500/50 text-green-400 px-4 py-2 rounded-lg mb-4 text-xs font-bold text-center uppercase tracking-wider relative z-10">@TempData["Success"]</div>
        }

        <form asp-action="Login" method="post" class="space-y-4 relative z-10">
            <div>
                <label class="text-[#ffd700] text-[10px] font-black uppercase mb-1 block ml-1">Tài khoản</label>
                <div class="relative">
                    <i class="fa-solid fa-user absolute left-4 top-1/2 -translate-y-1/2 text-[#d4af37]"></i>
                    <input type="text" name="Username" value="@Model?.Username" placeholder="Nhập tên đăng nhập"
                           class="w-full bg-[#1a0a0a] border border-[#d4af37]/50 rounded-lg p-3.5 pl-10 outline-none focus:border-[#ffd700] focus:shadow-[0_0_10px_rgba(212,175,55,0.2)] text-white font-bold transition" />
                </div>
            </div>
            
            <div>
                <label class="text-[#ffd700] text-[10px] font-black uppercase mb-1 block ml-1">Mật khẩu</label>
                <div class="relative">
                    <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-[#d4af37]"></i>
                    <input type="password" name="Password" placeholder="Nhập mật khẩu"
                           class="w-full bg-[#1a0a0a] border border-[#d4af37]/50 rounded-lg p-3.5 pl-10 outline-none focus:border-[#ffd700] focus:shadow-[0_0_10px_rgba(212,175,55,0.2)] text-white font-bold transition" />
                </div>
            </div>

            <div class="pt-2">
                <button type="submit"
                        class="w-full bg-gradient-to-b from-[#ffd700] to-[#b8860b] text-black font-black text-lg py-3 rounded-lg shadow-[0_0_15px_rgba(212,175,55,0.4)] hover:scale-[1.02] transition uppercase tracking-widest">
                    Đăng Nhập Ngay
                </button>
            </div>
            
            <p class="text-center text-xs text-gray-400 font-bold pt-2 border-t border-white/5">
                Chưa có tài khoản? <a asp-action="Register" class="text-[#ffd700] hover:text-white transition uppercase">Đăng ký</a>
            </p>
        </form>
    </div>
</div>
