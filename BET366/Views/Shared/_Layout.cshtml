<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BET366 - Premium Casino</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-screen text-white pb-24 bg-black">
    <div class="fixed inset-0 pointer-events-none opacity-20 z-0">
        <div class="absolute top-0 left-1/4 w-64 h-64 bg-yellow-500 blur-[120px]"></div>
        <div class="absolute bottom-0 right-1/4 w-64 h-64 bg-blue-500 blur-[120px]"></div>
    </div>

    @RenderBody()

    <div id="toast" class="fixed top-24 left-1/2 -translate-x-1/2 z-[200] hidden px-8 py-4 rounded-full font-bold shadow-2xl transition-all duration-300 text-white"></div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
